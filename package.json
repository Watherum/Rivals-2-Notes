{
  "name": "rivals-2-notes",
  "private": true,
  "version": "6.1.0",
  "type": "module",
  "author": "Watherum",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite --host\"",
    "start": "npm run build && node server.js",
    "server": "node server.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.roa2notes.app",
    "productName": "RoA2 Notes",
    "copyright": "Watherum",
    "publish": null,
    "asar": false,
    "files": [
      "electron/**",
      "server.js",
      "dist/**",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "logos/**"
        ]
      }
    ],
    "win": {
      "target": "portable",
      "icon": "public/logos/RIVALS_2_LOGO_MAIN.png"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
